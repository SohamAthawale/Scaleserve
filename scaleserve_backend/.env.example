PORT=8080
DATABASE_URL=postgresql://scaleserve_app:your_db_password@localhost:5432/scaleserve
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=12h
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Gmail SMTP (required for forgot-password + MFA OTP)
SMTP_GMAIL_USER=your_sender@gmail.com
SMTP_GMAIL_APP_PASSWORD=your_16_char_gmail_app_password
SMTP_FROM_NAME=ScaleServe

# Optional: comma-separated origins, e.g. http://localhost:3000,http://localhost:8080
CORS_ORIGINS=

# If true, schema SQL is applied automatically on startup
AUTO_MIGRATE=true
